# ==========================================
# AI RECRUITMENT SYSTEM - ENVIRONMENT CONFIG
# Copy this file to .env and fill in your values
# ==========================================

# Server Configuration
PORT=5000
NODE_ENV=production

# Database (MongoDB)
# Option 1: MongoDB Atlas (Recommended for production)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-recruitment
#
# Option 2: Local MongoDB
# MONGO_URI=mongodb://localhost:27017/ai-recruitment
#
# Option 3: Leave blank to use in-memory MongoDB (testing only)
MONGO_URI=

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Google Gemini AI API Key
# Get your API key from: https://aistudio.google.com/app/apikey
# Without this, AI screening will use local fallback scoring
GEMINI_API_KEY=your-gemini-api-key-here

# File Upload Limits (in MB)
MAX_FILE_SIZE=10
