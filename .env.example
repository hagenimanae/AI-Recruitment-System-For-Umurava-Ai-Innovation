# ==========================================
# AI Recruitment System - Environment Variables
# Copy this file to backend/.env and frontend/.env.local
# ==========================================

# ------------------------------------------
# BACKEND (backend/.env)
# ------------------------------------------

# Server port (default: 5000)
PORT=5000

# Gemini API Key (Required for AI screening)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAg427c-_MLv72d7Wq172YegKCGHwsLvIY

# JWT Secret (Required for authentication)
# Generate a random string: openssl rand -base64 32
JWT_SECRET=elissa123//

# MongoDB Connection (Optional - defaults to localhost:27017)
# For local: MONGO_URI=mongodb://localhost:27017/ai-recruitment
# For MongoDB Atlas: MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/ai-recruitment
MONGO_URI=mongodb://localhost:27017/ai-recruitment

# Frontend URL (for CORS - required for production)
# Local: FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# ------------------------------------------
# FRONTEND (frontend/.env.local)
# ------------------------------------------
NEXT_PUBLIC_API_URL=https://ai-recruitment-system-for-umurava-ai.onrender.com/api
# Backend API URL (Required)
# Local: NEXT_PUBLIC_API_URL=http://localhost:5000
# Production: NEXT_PUBLIC_API_URL=https://your-backend.railway.app
NEXT_PUBLIC_API_URL=http://localhost:5000

# ==========================================
# DEPLOYMENT INSTRUCTIONS
# ==========================================

# 1. Local Development:
#    - Copy this to backend/.env
#    - Copy this to frontend/.env.local
#    - Run: npm run dev in both folders

# 2. Production Deployment:
#    Frontend (Vercel):
#    - Set NEXT_PUBLIC_API_URL to your backend URL
#    - Deploy from GitHub
#
#    Backend (Railway/Render):
#    - Set PORT=5000
#    - Set GEMINI_API_KEY
#    - Set MONGO_URI (MongoDB Atlas)
#    - Set FRONTEND_URL to your Vercel URL
#
#    Database (MongoDB Atlas):
#    - Create free cluster at mongodb.com/atlas
#    - Whitelist all IPs (0.0.0.0/0) for simplicity
#    - Copy connection string to MONGO_URI
